{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "host-debug",
      "displayName": "Host Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/host-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "LPC_ENABLE_TESTS": "ON"
      }
    },
    {
      "name": "host-release",
      "displayName": "Host Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/host-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "LPC_ENABLE_TESTS": "ON"
      }
    },
    {
      "name": "arm-gcc-debug",
      "displayName": "ARM GNU Baremetal Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/arm-gcc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/arm-none-eabi-gcc.cmake",
        "LPC_ENABLE_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-host-debug",
      "configurePreset": "host-debug"
    },
    {
      "name": "build-host-release",
      "configurePreset": "host-release"
    },
    {
      "name": "build-arm-gcc-debug",
      "configurePreset": "arm-gcc-debug"
    }
  ],
  "testPresets": [
    {
      "name": "test-host-debug",
      "configurePreset": "host-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
